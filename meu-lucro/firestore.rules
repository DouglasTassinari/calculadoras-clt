rules_version = '2';

// ============================================================
// Regras de segurança do Firestore — Meu Lucro
//
// Cada usuário só pode ler/escrever os próprios dados.
// A identidade é o UID do Firebase Authentication.
// Cole estas regras em: Firebase Console -> Firestore -> Regras.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Documento do usuário: users/{uid}
    // Guarda nome, veículo, metas e custo por km.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Registros diários: users/{uid}/records/{recordId}
      match /records/{recordId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Tudo o que não casar com as regras acima é negado por padrão.
  }
}
